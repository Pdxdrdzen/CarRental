<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="720.0" prefWidth="1180.0" styleClass="wall-bg" stylesheets="@app.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
  <children>
    <HBox spacing="24.0" styleClass="surface-wrap" AnchorPane.bottomAnchor="26.0" AnchorPane.leftAnchor="26.0" AnchorPane.rightAnchor="26.0" AnchorPane.topAnchor="26.0">
      <padding>
        <Insets bottom="26.0" left="26.0" right="26.0" top="26.0" />
      </padding>
      <children>
        <VBox prefWidth="430.0" spacing="16.0" styleClass="side-card">
          <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
          </padding>
          <children>
            <Label styleClass="badge-label" text="Wypożyczalnia samochodów" />
            <Label styleClass="page-title neon-pink" text="Logowanie" textFill="WHITE" />
            <Label styleClass="body-text" text="Zaloguj się, aby przeglądać samochody, tworzyć rezerwacje i korzystać z dostępnych funkcji systemu." wrapText="true" />
            <VBox spacing="12.0">
              <children>
                <Label styleClass="list-chip" text="Panel użytkownika" />
                <Label styleClass="list-chip" text="Panel administratora" />
                <Label prefHeight="35.0" prefWidth="188.0" styleClass="list-chip" text="Szybki dostęp do rezerwacji" />
              </children>
            </VBox>
            <Region prefHeight="10.0" />
            <Label styleClass="section-title neon-cyan" textFill="WHITE" />
          </children>
        </VBox>
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
          <children>
            <VBox maxWidth="400.0" spacing="16.0" styleClass="main-card">
              <padding>
                <Insets bottom="34.0" left="34.0" right="34.0" top="34.0" />
              </padding>
              <children>
                <Label styleClass="section-title neon-cyan" text="Zaloguj się" textFill="WHITE" />
                <Label styleClass="subtitle" text="Wpisz dane i wybierz odpowiedni panel." wrapText="true" />
                <VBox spacing="8.0">
                  <children>
                    <Label styleClass="field-label" text="Login lub e-mail" />
                    <TextField fx:id="loginField" prefHeight="44.0" promptText="np. admin@uczelnia.pl" styleClass="neon-input" />
                  </children>
                </VBox>
                <VBox spacing="8.0">
                  <children>
                    <Label styleClass="field-label" text="Hasło" />
                    <PasswordField fx:id="passwordField" prefHeight="44.0" promptText="Wpisz hasło" styleClass="neon-input" />
                  </children>
                </VBox>
                <Button fx:id="loginButton" mnemonicParsing="false" prefHeight="46.0" styleClass="neon-button primary-button" text="Zaloguj" />
                <Button fx:id="adminButton" mnemonicParsing="false" prefHeight="46.0" styleClass="neon-button secondary-button" text="Panel administratora" />
                <HBox spacing="6.0">
                  <children>
                    <Label styleClass="soft-text" text="Nie masz konta?" />
                    <Hyperlink fx:id="goToRegisterLink" text="Zarejestruj się" />
                  </children>
                </HBox>
              </children>
            </VBox>
          </children>
        </VBox>
      </children>
    </HBox>
  </children>
</AnchorPane>
