<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="840.0" prefWidth="1320.0" styleClass="wall-bg" stylesheets="@app.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
  <children>
    <BorderPane styleClass="surface-wrap" AnchorPane.bottomAnchor="22.0" AnchorPane.leftAnchor="22.0" AnchorPane.rightAnchor="22.0" AnchorPane.topAnchor="22.0">
      <top>
        <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="top-bar">
          <padding>
            <Insets bottom="16.0" left="24.0" right="24.0" top="16.0" />
          </padding>
          <children>
            <Label styleClass="badge-label" text="Wypożyczalnia samochodów" />
            <Label styleClass="section-title neon-cyan" text="Panel administratora" textFill="WHITE" />
            <Region HBox.hgrow="ALWAYS" />
            <TextField prefHeight="40.0" prefWidth="240.0" promptText="Szukaj auta lub rezerwacji..." styleClass="neon-input" />
            <Button mnemonicParsing="false" styleClass="neon-button ghost-button" text="Powiadomienia" />
            <Button mnemonicParsing="false" styleClass="neon-button secondary-button" text="Wyloguj" />
          </children>
        </HBox>
      </top>
      <left>
        <VBox prefWidth="250.0" spacing="14.0" styleClass="side-card" BorderPane.alignment="TOP_LEFT">
          <padding>
            <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
          </padding>
          <children>
            <Label styleClass="section-title neon-pink" text="Nawigacja" textFill="WHITE" />
            <Button mnemonicParsing="false" styleClass="neon-button primary-button" text="Pojazdy" />
            <Button mnemonicParsing="false" styleClass="neon-button ghost-button" text="Rezerwacje" />
            <Button mnemonicParsing="false" styleClass="neon-button ghost-button" text="Użytkownicy" />
            <Button mnemonicParsing="false" styleClass="neon-button ghost-button" text="Raporty" />
            <Separator />
            <Label styleClass="soft-text" text="Status systemu" />
            <Label styleClass="list-chip" text="Flota: 128 pojazdów" />
            <Label styleClass="list-chip" text="Aktywne rezerwacje: 37" />
            <Label styleClass="list-chip" text="Serwis dziś: 4 auta" />
          </children>
        </VBox>
      </left>
      <center>
        <VBox spacing="18.0" BorderPane.alignment="CENTER">
          <padding>
            <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
          </padding>
          <children>
            <HBox spacing="16.0">
              <children>
                <VBox spacing="8.0" styleClass="metric-card" HBox.hgrow="ALWAYS">
                  <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0" /></padding>
                  <children>
                    <Label styleClass="soft-text" text="Dostępne pojazdy" />
                    <Label styleClass="metric-number neon-cyan" text="86" textFill="WHITE" />
                  </children>
                </VBox>
                <VBox spacing="8.0" styleClass="metric-card" HBox.hgrow="ALWAYS">
                  <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0" /></padding>
                  <children>
                    <Label styleClass="soft-text" text="Nowe rezerwacje" />
                    <Label styleClass="metric-number neon-pink" text="14" textFill="WHITE" />
                  </children>
                </VBox>
                <VBox spacing="8.0" styleClass="metric-card" HBox.hgrow="ALWAYS">
                  <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0" /></padding>
                  <children>
                    <Label styleClass="soft-text" text="Auta w serwisie" />
                    <Label styleClass="metric-number neon-cyan" text="04" textFill="WHITE" />
                  </children>
                </VBox>
              </children>
            </HBox>
            <HBox spacing="18.0" VBox.vgrow="ALWAYS">
              <children>
                <VBox spacing="14.0" styleClass="table-box" HBox.hgrow="ALWAYS">
                  <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                  <children>
                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                      <children>
                        <Label styleClass="section-title neon-cyan" text="Flota pojazdów" textFill="WHITE" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" styleClass="neon-button primary-button" text="Dodaj pojazd" />
                      </children>
                    </HBox>
                    <TableView prefHeight="420.0" styleClass="neon-table" VBox.vgrow="ALWAYS">
                      <columns>
                        <TableColumn prefWidth="180.0" text="Model" />
                        <TableColumn prefWidth="120.0" text="Rok" />
                        <TableColumn prefWidth="140.0" text="Status" />
                        <TableColumn prefWidth="160.0" text="Cena / dzień" />
                      </columns>
                    </TableView>
                  </children>
                </VBox>
                <VBox prefWidth="290.0" spacing="14.0" styleClass="side-card">
                  <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                  <children>
                    <Label styleClass="section-title neon-pink" text="Szybkie akcje" textFill="WHITE" />
                    <Button mnemonicParsing="false" styleClass="neon-button secondary-button" text="Dodaj rezerwację ręcznie" />
                    <Button mnemonicParsing="false" styleClass="neon-button ghost-button" text="Edytuj użytkownika" />
                    <Button mnemonicParsing="false" styleClass="neon-button ghost-button" text="Oznacz auto jako serwis" />
                    <Separator />
                    <Label styleClass="soft-text" text="Ostatnia aktywność" />
                    <Label styleClass="info-text" text="BMW 3 Touring dodane do floty" wrapText="true" />
                    <Label styleClass="info-text" text="Rezerwacja #204 potwierdzona" wrapText="true" />
                    <Label styleClass="info-text" text="Toyota Corolla wróciła z wypożyczenia" wrapText="true" />
                  </children>
                </VBox>
              </children>
            </HBox>
          </children>
        </VBox>
      </center>
    </BorderPane>
  </children>
</AnchorPane>
